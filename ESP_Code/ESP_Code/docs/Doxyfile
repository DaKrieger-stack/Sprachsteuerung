# Doxygen-Konfiguration — ESP32 Sprachsteuerung
# Ausführen: doxygen docs/Doxyfile  (im Verzeichnis ESP_Code/ESP_Code)

PROJECT_NAME           = "ESP32 Sprachsteuerung"
PROJECT_BRIEF          = "SPH0645 I2S → Mel-Spektrogramm → TFLite → CAN"
PROJECT_NUMBER         =
OUTPUT_DIRECTORY       = docs/html
CREATE_SUBDIRS         = NO
OUTPUT_LANGUAGE        = German

INPUT                  = src/main.cpp include/modell.h docs/mainpage.md
INPUT_ENCODING         = UTF-8
FILE_PATTERNS          = *.cpp *.h *.md
RECURSIVE              = NO
EXCLUDE                = src/modell.c
EXCLUDE_PATTERNS       =

USE_MDFILE_AS_MAINPAGE = docs/mainpage.md

GENERATE_HTML          = YES
GENERATE_LATEX         = NO
HTML_OUTPUT            = .
HTML_TIMESTAMP         = YES

EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = YES
EXTRACT_LOCAL_CLASSES  = YES
HIDE_UNDOC_MEMBERS     = NO
HIDE_UNDOC_CLASSES     = NO

JAVADOC_AUTOBRIEF      = YES
QT_AUTOBRIEF           = NO
MULTILINE_CPP_IS_BRIEF = YES
BRIEF_MEMBER_DESC      = YES
REPEAT_BRIEF           = YES
ALWAYS_DETAILED_SEC    = NO

OPTIMIZE_OUTPUT_FOR_C  = NO
MARKDOWN_SUPPORT       = YES

SOURCE_BROWSER         = YES
INLINE_SOURCES         = NO
REFERENCED_BY_RELATION = YES
REFERENCES_RELATION    = YES

HAVE_DOT               = NO

QUIET                  = NO
WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = YES
WARN_IF_DOC_ERROR      = YES
